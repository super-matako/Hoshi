{
  "name": "Hoshi",
  "productName": "Hoshi",
  "version": "1.0.5",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.hoshi.goapp",
    "files": [
      "**/*",
      "!KataGo/**/*",
      "!KataGo"
    ],
    "win": {
      "target": "portable",
      "icon": "icon.ico"
    },
    "portable": {
      "artifactName": "Hoshi_${version}_${arch}.exe"
    },
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  }
}
