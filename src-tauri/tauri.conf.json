{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hoshi",
  "version": "1.5.0",
  "identifier": "com.hoshi.goapp",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Hoshi",
        "width": 1800,
        "height": 900,
        "transparent": false,
        "backgroundColor": "#8f8074",
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Game",
    "copyright": "Copyright © 2026 The Hoshi Project",
    "shortDescription": "SGF viewer/editor and KataGo GUI.",
    "longDescription": "A lightweight viewer and editor for SGF files, as well as a visual frontend for KataGo AI to analyze one's Go games.",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
